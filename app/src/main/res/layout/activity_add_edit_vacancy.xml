<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Создание вакансии"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_company_name"
            style="@style/LoginTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Название компании"
            android:background="@drawable/ios_edittext_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/et_vacancy_title"
            style="@style/LoginTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Заголовок вакансии"
            android:background="@drawable/ios_edittext_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/et_salary_min"
                style="@style/LoginTextInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="ЗП от"
                android:inputType="number"
                android:background="@drawable/ios_edittext_background"
                android:padding="16dp"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/et_salary_max"
                style="@style/LoginTextInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="ЗП до"
                android:inputType="number"
                android:background="@drawable/ios_edittext_background"
                android:padding="16dp"/>
        </LinearLayout>

        <EditText
            android:id="@+id/et_city"
            style="@style/LoginTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Город"
            android:background="@drawable/ios_edittext_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/et_description"
            style="@style/LoginTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Описание"
            android:minLines="3"
            android:gravity="top"
            android:background="@drawable/ios_edittext_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/et_requirements"
            style="@style/LoginTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Требования"
            android:minLines="3"
            android:gravity="top"
            android:background="@drawable/ios_edittext_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/et_work_type"
            style="@style/LoginTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Тип занятости (напр. Полная занятость)"
            android:background="@drawable/ios_edittext_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/et_job_format"
            style="@style/LoginTextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Формат (напр. Удалённо или В офисе)"
            android:background="@drawable/ios_edittext_background"
            android:padding="16dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_save_vacancy"
            style="@style/SettingsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Сохранить" />

        <Button
            android:id="@+id/btn_delete_vacancy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/primary_red"
            android:padding="16dp"
            android:text="Удалить вакансию"
            android:textColor="@android:color/white"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
