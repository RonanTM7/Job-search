rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Вспомогательная функция для проверки админа
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Правила для админов: видят и редактируют всё
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Соискатели (Seekers)
    match /seekers/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Работодатели (Employers)
    match /employers/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Вакансии: видят все, создают/правят только работодатели (или админ)
    match /vacancies/{id} {
      allow read: if true;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/employers/$(request.auth.uid));
    }

    // Резюме: видит владелец и работодатели (или админ)
    match /resumes/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && id == request.auth.uid;
    }

    // Отклики (Applications)
    match /applications/{id} {
      allow read, write: if request.auth != null;
    }

    // Обычные чаты (с поддержкой)
    match /chats/{chatId} {
      allow read, write: if chatId.startsWith('guest_') || (request.auth != null && request.auth.uid == chatId);
      match /messages/{messageId} {
        allow read, write: if chatId.startsWith('guest_') || (request.auth != null && request.auth.uid == chatId);
      }
    }

    // Чаты между соискателем и работодателем
    match /employer_chats/{chatId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    match /updates/{updateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /favorites/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
